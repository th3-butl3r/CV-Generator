PYTHONPATH="src"
ENVIRONMENT="LOCAL"

# ─── Jina AI Reader ──────────────────────────────────────────────────────────
# Obtén tu clave gratuita en https://jina.ai/reader/
LOCAL_JINA_AI="tu-clave-jina-aqui"
DOCKER_JINA_AI="tu-clave-jina-aqui"

# ─── Ollama ───────────────────────────────────────────────────────────────────
# LOCAL: Ollama corriendo en tu máquina  |  DOCKER: servicio interno de compose
LOCAL_OLLAMA_HOST="http://localhost:11434"
DOCKER_OLLAMA_HOST="http://ollama:11434"

LOCAL_LLM_MODEL="qwen2.5:0.5b"
DOCKER_LLM_MODEL="qwen2.5:0.5b"
