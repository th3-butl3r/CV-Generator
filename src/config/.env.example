PYTHONPATH="src"
ENVIRONMENT="LOCAL"

# ─── Jina AI Reader ─────────────────────────────────────────────────────────
# Obtén tu clave gratuita en https://jina.ai/reader/
LOCAL_JINA_AI="tu-clave-jina-aqui"
DOCKER_JINA_AI="tu-clave-jina-aqui"

# ─── LLM (Ollama) ────────────────────────────────────────────────────────────
# LOCAL: Ollama corriendo en tu máquina  |  DOCKER: servicio interno de compose
LOCAL_LLM_BASE_URL="http://localhost:11434/v1"
DOCKER_LLM_BASE_URL="http://ollama:11434/v1"

LOCAL_LLM_MODEL="qwen2.5:1.5b"
DOCKER_LLM_MODEL="qwen2.5:1.5b"

# Ollama no requiere una clave real; cualquier valor no vacío funciona
LOCAL_LLM_API_KEY="ollama"
DOCKER_LLM_API_KEY="ollama"

LOCAL_LLM_TIMEOUT_SECONDS="60"
DOCKER_LLM_TIMEOUT_SECONDS="60"
