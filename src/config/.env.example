PYTHONPATH="src"
ENVIRONMENT="LOCAL"

# ─── Jina AI Reader ──────────────────────────────────────────────────────────
# Obtén tu clave gratuita en https://jina.ai/reader/
LOCAL_JINA_AI="tu-clave-jina-aqui"
DOCKER_JINA_AI="tu-clave-jina-aqui"

# ─── Proveedor LLM ───────────────────────────────────────────────────────────
# Valores válidos: "openrouter" | "ollama"
LOCAL_LLM_PROVIDER="openrouter"
DOCKER_LLM_PROVIDER="openrouter"

# ─── OpenRouter (LLM_PROVIDER=openrouter) ────────────────────────────────────
# Obtén tu clave en https://openrouter.ai/keys
LOCAL_OPENROUTER_API_KEY="tu-clave-openrouter-aqui"
DOCKER_OPENROUTER_API_KEY="tu-clave-openrouter-aqui"

LOCAL_OPENROUTER_MODEL="google/gemma-3-27b-it:free"
DOCKER_OPENROUTER_MODEL="google/gemma-3-27b-it:free"

# ─── Ollama (LLM_PROVIDER=ollama) ────────────────────────────────────────────
# LOCAL: Ollama corriendo en tu máquina  |  DOCKER: servicio interno de compose
# Para Docker arranca con: docker compose --profile ollama up
LOCAL_OLLAMA_HOST="http://localhost:11434"
DOCKER_OLLAMA_HOST="http://ollama:11434"

LOCAL_OLLAMA_MODEL="qwen2.5:0.5b"
DOCKER_OLLAMA_MODEL="qwen2.5:0.5b"
